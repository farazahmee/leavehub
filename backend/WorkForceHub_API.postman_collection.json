{
	"info": {
		"_postman_id": "workforcehub-api-v1",
		"name": "WorkForceHub API",
		"description": "HR Management System API - WorkForceHub Backend. Base URL: {{base_url}}. Use Login request then set collection variable `access_token` from response, or use Bearer token in Authorization.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8080" },
		{ "key": "access_token", "value": "" }
	],
	"item": [
		{
			"name": "Health & Info",
			"description": "Root and health check endpoints (no auth).",
			"item": [
				{
					"name": "Root",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/",
						"description": "API info and docs link."
					},
					"response": []
				},
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/health",
						"description": "Health check for load balancers / monitoring."
					},
					"response": []
				}
			]
		},
		{
			"name": "Authentication",
			"description": "Sign up, login, set password, and current user. Login uses form-data; others use JSON where applicable.",
			"item": [
				{
					"name": "Signup",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"company_name\": \"Acme Inc\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
						},
						"url": "{{base_url}}/api/v1/auth/signup",
						"description": "Create account: first name, last name, company, email, password."
					},
					"response": []
				},
				{
					"name": "Register (internal)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"johndoe\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"employee\"\n}"
						},
						"url": "{{base_url}}/api/v1/auth/register",
						"description": "Register with username and role (internal use)."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json.success && json.data && json.data.access_token) {",
									"  pm.collectionVariables.set('access_token', json.data.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "username", "value": "admin", "type": "text" },
								{ "key": "password", "value": "your_password", "type": "text" },
								{ "key": "remember_me", "value": "false", "type": "text" }
							]
						},
						"url": "{{base_url}}/api/v1/auth/login",
						"description": "Login with username (or email) and password. Use remember_me=true for longer session. Saves access_token to collection variable if test runs."
					},
					"response": []
				},
				{
					"name": "Set Password",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"token-from-email-link\",\n  \"new_password\": \"NewSecurePass123!\"\n}"
						},
						"url": "{{base_url}}/api/v1/auth/set-password",
						"description": "Set password using token from admin-created user email."
					},
					"response": []
				},
				{
					"name": "Get Current User (Me)",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/api/v1/auth/me",
						"description": "Get current authenticated user info."
					},
					"response": []
				},
				{
					"name": "Test Email (Super Admin)",
					"request": {
						"method": "POST",
						"header": [],
						"url": "{{base_url}}/api/v1/auth/test-email?to_email=admin@example.com",
						"description": "Send test email for SMTP debugging. Super admin only."
					},
					"response": []
				}
			]
		},
		{
			"name": "Google Auth",
			"description": "Google OAuth status and token exchange (for SPA).",
			"item": [
				{
					"name": "Google OAuth Status",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": "{{base_url}}/api/v1/auth/google/status",
						"description": "Check if Google OAuth is configured."
					},
					"response": []
				},
				{
					"name": "Google Token Exchange",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [ { "key": "Content-Type", "value": "application/json" } ],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"google-auth-code-from-frontend\"\n}"
						},
						"url": "{{base_url}}/api/v1/auth/google/token?code=GOOGLE_CODE_HERE",
						"description": "Exchange Google OAuth code for JWT. Pass code as query param or in body if API accepts."
					},
					"response": []
				}
			]
		},
